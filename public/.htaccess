# Lagatama Craft — Public web root (recommended production document root)

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Redirect legacy login routes
    RewriteRule ^login\.php$ index.php [L,R=301]
    RewriteRule ^signIn\.php$ index.php [L,R=301]
    RewriteRule ^adminLogIn\.php$ admin/adminSignIn.php [L,R=301]
</IfModule>

<FilesMatch "^(\.env|composer\.(json|lock))$">
    Require all denied
</FilesMatch>

<FilesMatch "\.(sql|log|ini|bak)$">
    Require all denied
</FilesMatch>

<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
    Header always set Cross-Origin-Opener-Policy "same-origin-allow-popups"
</IfModule>

Options -Indexes
