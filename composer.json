{
    "name": "lagatama/craft",
    "description": "Lagatama Craft ecommerce application",
    "type": "project",
    "require": {
        "php": ">=8.0",
        "vlucas/phpdotenv": "^5.6",
        "phpmailer/phpmailer": "^6.9"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "serve": "php -S 127.0.0.1:8888 -t public public/router.php"
    }
