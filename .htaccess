# Lagatama Craft — project root (DocumentRoot should be public/)

# If Apache is pointed here by mistake, forward web requests to public/
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^$ public/ [L]
    RewriteRule ^((?!public/|app/|config/|database/|resources/|storage/|tools/|vendor/|views/).*)$ public/$1 [L]
</IfModule>

<FilesMatch "^(\.env|composer\.(json|lock))$">
    Require all denied
</FilesMatch>

Options -Indexes
